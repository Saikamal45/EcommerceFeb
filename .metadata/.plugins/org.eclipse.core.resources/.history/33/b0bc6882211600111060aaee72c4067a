# ===============================
# USER SERVICE API ROUTE
# ===============================
spring.cloud.gateway.routes[0].id=user-service
spring.cloud.gateway.routes[0].uri=lb://USER-SERVICE
spring.cloud.gateway.routes[0].predicates[0]=Path=/user-service/**
spring.cloud.gateway.routes[0].filters[0]=StripPrefix=1

# ===============================
# USER SERVICE SWAGGER ROUTE
# ===============================
spring.cloud.gateway.routes[1].id=user-service-swagger
spring.cloud.gateway.routes[1].uri=lb://USER-SERVICE
spring.cloud.gateway.routes[1].predicates[0]=Path=/user-service/swagger-ui/**,/user-service/v3/api-docs/**
spring.cloud.gateway.routes[1].filters[0]=StripPrefix=1

spring.config.import=optional:configserver:http://localhost:8087
